rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }

    // Secrets: Allow any logged-in user to read the API key
    // This is required for AI features to work for your users
    match /secrets/{secretId} {
      allow read: if isSignedIn();
      allow write: if false; // Only edit manually in Firebase Console
    }

    // Users: Only owner can read/write their profile
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // People: Only owner can read/write their contacts
    match /people/{personId} {
      // EXISTING: Owner can read/write
      allow read, write: if isSignedIn() && (
        (resource == null && request.resource.data.user_id == request.auth.uid) ||
        (resource != null && resource.data.user_id == request.auth.uid)
      );
      
      // NEW: Allow public to view a specific landing page (read single doc)
      // This is what makes the shared link work for friends without accounts
      allow get: if true;

      // NEW: Messages Subcollection (The Surprise Box)
      match /messages/{messageId} {
        // Anyone can contribute a surprise to the box
        allow create: if true;
        // Only the owner of the 'people' record can read the messages
        allow read: if isSignedIn() && 
          get(/databases/$(database)/documents/people/$(personId)).data.user_id == request.auth.uid;
      }
      
      // EXISTING: Subcollections (tasks, memories)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    // Notifications: Only owner can access
    match /notifications/{notifId} {
      allow read, write: if isSignedIn() && (
        (resource == null && request.resource.data.user_id == request.auth.uid) ||
        (resource != null && resource.data.user_id == request.auth.uid)
      );
    }

    // Groups: Only creator can access
    match /groups/{groupId} {
      allow read, write: if isSignedIn() && (
        (resource == null && request.resource.data.created_by == request.auth.uid) ||
        (resource != null && resource.data.created_by == request.auth.uid)
      );
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
